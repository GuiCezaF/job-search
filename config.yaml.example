search:
  schedule: "0 9 * * *"
  max_jobs_per_query: 35
  keywords:
    - "Python Developer"
    - "Backend Engineer"
    - "Software Engineer"
  experience_levels:
    - "Entry level"
    - "Associate"
    - "Mid-Senior level"
  locations:
    - "Brazil"
    - "Remote"

linkedin:
  username: "optional-if-using-env"
  password: "optional-if-using-env"

discord:
  webhook_url: "optional-if-using-env"

google_drive:
  enabled: false
  folder_id: ""
